generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Store {
  id          Int      @id @default(autoincrement())
  storeId     Int      @unique
  userId      Int
  accessToken String
  scope       String?
  tokenType   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
